# =============================================================================
# FRONTEND (Vite) - Configure in Vercel Dashboard > Settings > Environment Variables
# =============================================================================
# IMPORTANT: Variables must start with VITE_ to be exposed to the browser!

# Your Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
VITE_API_KEY=your_google_gemini_api_key

# Your Django backend API URL (e.g., deployed on Railway)
VITE_API_BASE_URL=https://your-backend-domain.com/api

# =============================================================================
# BACKEND (Django) - Configure in Railway Dashboard > Variables
# =============================================================================
# These are server-side only and should NOT be exposed to the browser

# Backend API Key (for Django to call Gemini)
GEMINI_API_KEY=your_google_gemini_api_key

# Registration Key (optional - leave empty to allow open registration)
REGISTRATION_KEY=

# Django Secret Key
SECRET_KEY=your_django_secret_key

# Debug mode (set to False for production)
DEBUG=False

# Allowed hosts for Django
ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1

# Database URL (Railway provides this)
DATABASE_URL=postgres://user:password@host:port/dbname

# CORS origins (your Vercel frontend URL)
CORS_ALLOWED_ORIGINS=https://your-vercel-frontend.vercel.app
